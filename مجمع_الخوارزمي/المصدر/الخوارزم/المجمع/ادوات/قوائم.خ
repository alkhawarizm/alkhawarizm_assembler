 الرزمة		 الخوارزم.المجمع.ادوات 	

استعمل			الخوارزم.المجمع.تفريغ.تفريغ_الهدف
 
(۩۩	

		+-------+        +------------+        +------------+        +-----------+
      | اول |------->| عقدة (رسالة) |------->| عقدة(اصل) |------->|   وهمية   |
      +-------+        +------------+        +------------+        +-----------+
                                                    ^                    |
                                     +--------------+                    V
                                     |                                ( عدم )
                               +------------+
                               	|اخير    |
                               +------------+

		۩۩)


الصنف	قوائم	{

	النوع		عقدة		شيء 	{
				تالي			ۢ عقدة
				سابق			ۢ	عقدة
	}؛

	النوع		قائمة		شيء 	{
			اول			ۢ عقدة	
			وهمية		ۢ عقدة		؛		(۩		 dummy 	۩)
			اخير			ۢ عقدة				
	}؛

	النوع		م_عقدة		ۢ	عقدة
	
	الدالة			(	 بمرجع 	ق  قائمة	)	تهيئة()		{
					ق.اول    :=( ؏ ق.وهمية )		كما ۢ عقدة
					ق.وهمية	:=	عدم							
					ق.اخير	:=	  ( ؏ ق.اول   )	 	كما ۢ عقدة		
	}		

	
الدالة (بمرجع ق قائمة) طولها() صحيح طبيعي {
    المتغير عد صحيح طبيعي := 0
    المتغير ع ۢ عقدة := ق.اول
    مادام ع ليس= عدم {
        عد++
        ع := ع->تالي
    }
    ارجع عد
}


	الدالة (بمرجع ق قائمة) اضف_ذيل(ع ۢ عقدة) {
	    ع->تالي := عدم
	    ع->سابق := ق.اخير
	    اذا ق.اخير ليس= عدم {
	        ق.اخير->تالي := ع
	    } والا {
	        ق.اول := ع
	    }
	    ق.اخير := ع
}


	الدالة			( 		ق  ۢ   قائمة	)	اضف_ذيل(	ع	ۢ عقدة		)		{
			المتغير		عق		ۢ عقدة	 :=		ق->اخير
					ع->تالي	:=		عق	->تالي	
					عق->تالي	:=	ع		
					ع->سابق	:=	عق
					ق->اخير	:=	ع				
	}			
	
	الدالة			(	ع	ۢ عقدة	 )	احذف_ذيل(			)		 	ۢ عقدة	{	
					ع->تالي->سابق	:=	ع->سابق
					ع->سابق->تالي	:=	ع->تالي				
					ارجع ع					
	}
	
	الدالة			(	 	ق ۢ قائمة )	احذف_راس(			)		 	ۢ عقدة	{	
				المتغير		ع 	ۢ عقدة	 :=		ق->اول
				اذا	ع->تالي	ليس= عدم {
					ق->اول	:=	ع->تالي
					ع->تالي->سابق	:=	ع->سابق

					ارجع ع					
				}
				ارجع عدم				
	}
}
