			اذا 	ڨ س =  رموز::حرف_تعليق {	ڨ س := '/0'		؛	}

			ارجع س			
	}

	
	(۩		   	۩)
		(۩۩		تخطي حروف المساحة	۩)			
		الدالة		تخطي	(	س ۢ حرف	)   ۢ حرف		{
					مادام	حرف_مساحة	(ڨ س)	{
						س++
					}
				ارجع س				
		}		

		
		(۩		   	۩)
		(۩۩	تبدأ التسميات المحلية بـ "." أو ينتهي بـ "۩": "1234 ۩"، ".1"	۩)			
		الدالة		حصل_وسم_محلي	(	بداية	ۢ 	ۢ 	حرف	)	ۢ حرف		{
				المتغير		س	ۢ	حرف		:=	ڨ بداية
				المتغير		اسم		ۢ حرف	:=	عدم

				اذا		ڨ س	=	'.'	{
					س++
					مادام		نصيات::رقمي(	ڨ	س	)		او ڨ س = '_'	{	(۩	'_' اللازمة ل ".\@"	۩)
						س++
					}
					اذا س > (	ڨ  بداية +  1   	)	{
(۩۩	الدالة		صناعة_وسم_محلي	(	عام  ۢ حرف،	طول_ع  صحيح ، محلي	ۢ حرف	، طول_م		صحيح 	)		ۢ حرف	{۩)
							
							اسم		:=		رموز::صناعة_وسم_محلي	(	عدم ، 0	،	ڨ بداية	،   (	س -  ( ڨ  بداية)	 ) كما صحيح )
							ڨ بداية	:=	تخطي	(	س	)						
					}
				} والا 	اذا 			نصيات::رقمي(	ڨ	س	)		او ڨ س = '_'	{	(۩	'_' اللازمة ل "/؏۩"	۩)	 
						س++
						مادام		 	نصيات::رقمي(	ڨ	س	)			{ 
							س++
						}
						اذا 	ڨ س = '۩'	و 		نصيات::رقمي(	 ڨ(س - 1)   )	{
							س++
							اسم		:=		رموز::صناعة_وسم_محلي	(	عدم ، 0	،	ڨ بداية	،  (	س -  ( ڨ  بداية)	 ) كما صحيح	)
							ڨ بداية	:=	تخطي	(	س	)									
						}
				}
				ارجع اسم			
		}		


		(۩	    	۩)
		الدالة		بادئة_جامد	(	س ۢ حرف،		اساس ۢ صحيح 	)		ۢ	حرف	{
			اذا  ليس	نصيات::رقمي	(	ڨ س	)	{
				ڨ اساس := 0
				ارجع س					
			}
			اذا ڨ س = '0'	{
				اذا س[1]	=	'س' {
					ڨ اساس := 16
					ارجع س + 2						
				}
				اذا س[1]	 = 'ث'	{
					ڨ اساس := 2
					 ارجع س + 2	
				}
				اذا   	نصيات::رقمي	(	ڨ س	)	{
					ڨ اساس := 8
					ارجع 	س						
				}
				اذا س[1]	=	'ص'	او 		س[1]	=	'ط'	او 	 س[1]	=	'ح'	 {
					س+=	2
				}
			}
			ڨ اساس	:= 10		
			ارجع س		
		 }						

		(۩	     	۩)		
		الدالة		لاحقة_جامد	(	س ۢ حرف،		نهاية  ۢ حرف 	)		ۢ	حرف	{
				س	؛		
				ارجع نهاية
		}
