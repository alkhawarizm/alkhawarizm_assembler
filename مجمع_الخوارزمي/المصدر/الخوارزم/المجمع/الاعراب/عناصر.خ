الدالة بناء_بايت_التعديل( ت ۢ عناصر::تعليمة ، ذ ۢ معالج::ذاكري  ) صحيح {
  
  المتغير سجل_افتراضي صحيح := -1 ؛
  المتغير ج ، عدد_وسائط_السجلات ، عدد_وسائط_الذاكرة صحيح طبيعي := 0 ، 0 ، 0 ؛

  (۩ 1. عد وسائط السجلات والذاكرة ۩)
  مادام ج < اكبر_عدد_معاملات {
    اذا ت->معاملات[ج]  ليس= عدم   {
		ليكن نوع_ := ت->معاملات[ج]->نوعه		
      اذا( ت->معاملات[ج]->نوعه وو معالج::سجل_اياكان) ليس= 0 {
	(۩ استثناء الفوري يدوياً لقطع الشك باليقين ۩)
                 عدد_وسائط_السجلات++ ؛ 
		 }  والا اذا ( ت->معاملات[ج]->نوعه وو معالج::سجل_ايماذاكرة)  ليس= 0 { عدد_وسائط_الذاكرة++ ؛ }
    }
    ج++ ؛
  }

  ت->تمديد.علامة اواو=  معالج::يحتاج_اسلوب_سجل_ذاكرة كما صحيح8 طبيعي؛

  (۩ 2. معالجة حالة وجود سجلين (سجل إلى سجل) ۩)
  اذا عدد_وسائط_السجلات = 2 {
   ج := (ت->معاملات[0]->نوعه وو معالج::سجل_اياكان) ليس= 0  ؟  0_ط : 1_ط ؛ (۩   السجل الأول ۩)
    ت->تمديد.اسذ.اسلوب := 3 ؛   (۩    وضع سجل-إلى-سجل۩)

    اذا   (ذ->نوع_المعامل[ج+1] وو سجل_اياكان)	ليس= 0	 {
      ت->تمديد.اسذ.سجل_ := ت->معاملات[ج+1]->سجل_قاعدة->رقمه	كما صحيح8 طبيعي	؛
      ت->تمديد.اسذ.سجل_او_ذاكرة := ت->معاملات[ج]->سجل_قاعدة->رقمه 		كما صحيح8 طبيعي؛
    } والا {
      ت->تمديد.اسذ.سجل_ := ت->معاملات[ج]->سجل_قاعدة->رقمه 		كما صحيح8 طبيعي؛
      ت->تمديد.اسذ.سجل_او_ذاكرة := ت->معاملات[ج+1]->سجل_قاعدة->رقمه 	كما صحيح8 طبيعي؛
    }
    }   والا { (۩ 3. معالجة حالة وجود معاملات ذاكرة ۩)
    اذا عدد_وسائط_الذاكرة ليس=0  {
      المتغير معاملات_ذاكرة ۢ  عناصر::معامل := ت->معاملات[(ت->معاملات[0]->نوعه وو سجل_ايماذاكرة)  ليس=0 ؟ 0 : ((ت->معاملات[1]->نوعه وو سجل_ايماذاكرة)   ليس=0 ؟ 1 : 2)] ؛
      سجل_افتراضي := رقم_سجل_دس ؛
      (۩ أ. حالة لا يوجد سجل قاعدة (عنوان مطلق) ۩)
      اذا معاملات_ذاكرة->سجل_قاعدة = عدم {
        ت->تمديد.اسذ.اسلوب := 0 ؛
        اذا معاملات_ذاكرة->سجل_فهرس = عدم {
          اذا 	معالج::علامة_الوضع() =	معالج::صفرة_64 {
            ت->تمديد.اسذ.سجل_او_ذاكرة := معالج::هروب_2_بيتات ؛
            ت->تمديد.مفق.قاعدة := معالج::سجل_بدون_قاعدة ؛
            ت->تمديد.مفق.فهرس := معالج::سجل_بدون_فهرس ؛
            ت->تمديد.علامة  اواو=   معالج::يحتاج_مقياس_فهرس_قاعدة ؛
			معاملات_ذاكرة->نوعه وو= متمم  معالج::سجل_ازاحة            
			معاملات_ذاكرة->نوعه اواو=    معالج::س_ازاحة_32_اضافي           			
          } والا {
            ت->تمديد.اسذ.سجل_او_ذاكرة := معالج::سجل_بدون_قاعدة ؛
			معاملات_ذاكرة->نوعه وو= متمم  معالج::سجل_ازاحة            
			معاملات_ذاكرة->نوعه اواو=    معالج::س_ازاحة_32              
          }
        } والا { (۩ لا يوجد قاعدة، يوجد فهرس فقط ۩)
          ت->تمديد.اسذ.سجل_او_ذاكرة := هروب_2_بيتات ؛
          ت->تمديد.مفق.قاعدة := معالج::سجل_بدون_قاعدة ؛
          ت->تمديد.مفق.فهرس := معاملات_ذاكرة->سجل_فهرس->رقمه كما صحيح8 طبيعي؛
