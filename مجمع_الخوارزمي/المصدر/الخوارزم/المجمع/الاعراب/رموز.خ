				اذا	ر->نوعه = 	وسم_مطلق		 {
					مخرج_.اكتب (مرفقات::حصل_العنوان(	(ر->عداد_البرنامج	)	 كما صحيح طبيعي))
				}  
				
				اذا	ر->نوعه = 	رمز_وسم		 {
					مخرج_.اكتب	( "	وسم" )
				} 				
				اذا	ر->نوعه = 	رمز_استيراد		 {
					مخرج_.اكتب	( "	استيراد	" )
				} 
				اذا		(	ر->علامة وو	( مستعمل اواو داخلي_للمجمع) ) ليس= 0 	   {
					مخرج_.اكتب	( "	   مستعمل	" )
				} 
				اذا		(	ر->علامة وو	  داخلي_للمجمع  ) ليس= 0 	 {
					مخرج_.اكتب	(	"	داخلي	"	)
				}  
				   اذا		(	ر->علامة وو	  تصدير  ) ليس= 0 	 {
					مخرج_.اكتب	(	"	تصدير	"	)
				} 
				
				  اذا		(	ر->علامة وو	  مشترك  ) ليس= 0 	 {
					مخرج_.اكتب	(	"	شائع	"	)
				} 
				  اذا		(	ر->علامة وو	  ضعيف  ) ليس= 0 	 {
					مخرج_.اكتب	(	"	ضعيف	"	)
				} 
				  اذا		(	ر->علامة وو	  محلي  ) ليس= 0 	 {
					مخرج_.اكتب	(	"	محلي	"	)
				}  
				  اذا		(	ر->علامة وو	  محمي  ) ليس= 0 	 {
					مخرج_.اكتب	(	"	محمي	"	)
				} 
				  اذا		(	ر->علامة وو	  مشار_اليه  ) ليس= 0 	 {
					مخرج_.اكتب	(	"مشار_اليه	"	)
				}  
				 اذا		(	ر->علامة وو	  وسم_مطلق  ) ليس= 0 	 {
					مخرج_.اكتب	(	"	وسم_مطلق	"	)
				 } 		
				 اذا		(	ر->علامة وو	  معادل  ) ليس= 0 	 {
					مخرج_.اكتب	(	"	معادل	"	)
				 }		
				 اذا		(	ر->علامة وو	  قائمة_مسجلات  ) ليس= 0 	 {
					 مخرج_.اكتب	(		"	قائمة_مسجلات	"	)
				  }	
				اذا		ر.نوعه() ليس= 0 {
							ر.اطبع_نوع(مخرج_ )						
				}		
				اذا		ر->حجم_من_تعبير ليس= عدم  {
					(۩	شاشة::اكتب	(	ر->حجمه	)	۩)
				}
				مخرج_.اكتب	(	"	تراصف=  "	) ؛ مخرج_.اكتب	(ر->تراصف كما صحيح طبيعي)			
	}		
	
	الدالة		اطبع_الرموز(	مخرج_ ملفات::ملف ) {
				المتغير  ر  ۢ رمز := الرمز_الاول_
				مخرج_.اكتب("الرموز:/س")
				مادام ر ليس= عدم {
						ر.اطبع(مخرج_)؛ مخرج_.اكتب("/س")
						ر := ر->تالي						
				}					
	}
	
		(۩		     	۩)	
	(۩۩		إنشاء وسم محلي للنموذج:   "" + اسم_وسم_عام + "" + اسم_وسم_محلي	۩)			
	الدالة		صناعة_وسم_محلي (	عام  ۢ حرف،	طول_ع  صحيح ، محلي	ۢ حرف	، طول_م		صحيح 	) ۢ حرف	{
				المتغير		اسم ، م		ۢ حرف	
				اذا 	طول_ع = 0 			{
					(۩	استخدام آخر تسمية عامة محددة	۩)
					عام			:=			آخر_وسم_عام			
					طول_ع	:=			آخر_وسم_عام.طولها()			
				}
				م	:=	اسم		:=	ذاكرة::تخصيص(	(طول_م + طول_ع	 +  3) كما صحيح طبيعي 	)		كما  ۢ حرف
				ڨ م++ :=	' '
				اذا			طول_ع	> 0	{
					ذاكرة::نسخ	(	م،	عام	،	طول_ع	كما صحيح طبيعي )
					م+=		طول_ع				
				}
				ڨ م++ :=	' '			
				 ذاكرة::نسخ	(	م،	محلي	،	طول_م	كما صحيح طبيعي )						
				ڨ (	م	+	طول_م	)	:=	'/0'
				ارجع اسم				
	}		
	

	(۩۩		نوع مراجع الرمز		۩)
	(۩۩		تاكد من مرجع محلي			۩)
	الدالة		هل_مرجع_محلي	( ر ۢ رمز	 ) منطقي	{
			ارجع 	ر->نوعه	=	رمز_وسم	 و (ر->علامة	وو ضعيف) ليس= 0
	}			
	(۩۩		تاكد من مرجع خارجي 	۩)	
	الدالة		هل_مرجع_خارجي	( ر ۢ رمز )	 منطقي	{
				ارجع 	ر->نوعه	=	رمز_استيراد		او		(ر->علامة	وو ضعيف) ليس= 0
	 }	
		
	(۩		    		۩)
	الدالة		تحقق_من_الرموز_المبهمة () {
		المتغير		ر		ۢ رمز := الرمز_الاول_
		مادام ر ليس= عدم {
			اذا ليس استيراد_آلي_ و ر->نوعه = رمز_استيراد و (ر->علامة وو (تصدير اواو مشترك اواو ضعيف)) = 0 {
				ليكن اسم := 	ر->اسمه		
				اخطاء::اكتب_خطا_عام(22 (۩ ۩)) ؛  (۩ BUG: ر->اسمه ۩)
			} والا اذا ر->نوعه = رمز_استيراد و (ر->علامة وو مشار_اليه) = 0 {
				ليكن اسم := 	ر->اسمه						
				اخطاء::اكتب_خطا_عام(61 (۩ ۩)) ؛ (۩ BUG: ر->اسمه ۩)
			}
			ر := ر->تالي
		}
	}
	
	
	الدالة		رمز_جديد	(	اسم ۢ	حرف ، نوع_ صحيح طبيعي ، علامات صحيح طبيعي	)		ۢ		رمز {
		المتغير	جديد		ۢ	 رمز := ذاكرة::تخصيص	(	حجم(	رمز)	)	كما  م_رمز
		جديد->اسمه				:=	نصيات::نسخ(اسم)
		جديد->نوعه 				:= نوع_
		جديد->علامة				:= علامات
		جديد->تراصف				:= 1
		جديد->مقتطع_			:= عدم 
		جديد->تعبير				:= عدم
		جديد->حجم_من_تعبير		:= عدم
		ارجع جديد
	}
	
