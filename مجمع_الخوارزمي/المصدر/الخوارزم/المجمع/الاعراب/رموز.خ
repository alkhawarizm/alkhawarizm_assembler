	الدالة		استعادة_رموز	()	{
		المتغير		اول_محمي ،	اخر_محمي،	م_رمز		ۢ 	رمز		:=	عدم	،	 عدم، عدم ؛		
					
			اذا 	الرمز_المحتفظ_		ليس= عدم {
