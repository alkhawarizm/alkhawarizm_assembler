						الرمز_الاول_	:=		م_رمز	->تالي
					اذا		(م_رمز	->علامة	وو محمي)	ليس= 0	{
								م_رمز	->تالي	:=	اول_محمي	
								اول_محمي	:=	م_رمز		
								اذا اخر_محمي	  = عدم {
									اخر_محمي		:=	م_رمز
								}
					} والا 	{
							جدول_تجزئة_الرموز.حذف_مدخل(	م_رمز->	 اسمه  	)		
							ذاكرة::تحرير	(	م_رمز	)				
					}
				}

				اذا		اول_محمي	ليس= عدم {
					اخر_محمي->تالي	:=	الرمز_الاول_
						الرمز_الاول_	:=	اول_محمي						
				}
				
				الرمز_المحتفظ_	:= عدم				
			}
	}		
