						} والا	{
							طابق عامل_مقياس_تقييم	{
								حالة 1 {  عامل_مقياس_تقييم := 0 ؛  }
								حالة 2 {  عامل_مقياس_تقييم := 1 ؛ } 
								حالة 4 {  عامل_مقياس_تقييم := 2 ؛  }
								حالة 8 {  عامل_مقياس_تقييم := 3 ؛  }
								حالة اخرى  { 
