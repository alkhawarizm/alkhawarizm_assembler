			(۩ حساب حجم التعليمة ۩)
			حجم_ := عناصر::حصل_حجم_المعامل(ت)

			حجم_ +=    ت->تمديد.رقم_بادئ كما صحيح طبيعي
			
			اذا (ت->تمديد.علامة وو معالج::يحتاج_اسلوب_سجل_ذاكرة) ليس= 0	{
