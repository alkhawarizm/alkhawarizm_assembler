					(۩ تحسين المعاملات ۩)
					ليكن نوعه := 	 ت->معاملات[ا]->نوعه			
					اذا (نوعه وو معالج::سجل_فوري) ليس= 0	{
						(۩ استخدم أصغر حجم فوري ۩)
(۩						تحسين_فوري(ت، ت->معاملات[ا]، مق، عداد، اخيرة)۩)
					} والا اذا (ت->معاملات[ا]->نوعه وو معالج::سجل_ازاحة) ليس= 0	{
