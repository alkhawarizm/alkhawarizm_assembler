(۩									تحسين_قفزة(ت->معاملات[ا]، مق، عداد، اخيرة)					۩)
						}	والا  {
							(۩ تحسين الإزاحة ۩)
(۩							تحسين_إزاحة(ت->معاملات[ا]، مق، عداد، اخيرة)۩)
						}
					}
					(۩ تقييم عامل المقياس إذا كان موجوداً ۩)
					اذا اخيرة = صواب و ت->معاملات[ا]->عامل_مقياس ليس= عدم	{
						اذا ليس تقييم_تعبير(ت->معاملات[ا]->قيمة، ؏عامل_مقياس_تقييم، مق، عداد)	{
							اخطاء::اكتب_خطا_معالج(18)	؛	 
