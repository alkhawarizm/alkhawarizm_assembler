									 }
							}
							
							ت->معاملات[ا]->مقياس_لوغ2 := عامل_مقياس_تقييم كما صحيح
						}
					} والا	{
						ت->معاملات[ا]->مقياس_لوغ2 := 0
					}
				}
				ا++
			}
