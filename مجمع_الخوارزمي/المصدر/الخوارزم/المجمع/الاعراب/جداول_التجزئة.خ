(۩		      	۩)

(۩۩ 			۩۩)
الصنف	جداول_التجزئة	{

النوع		بيان_تجزئة	وحدة {
		موشر		ايما
		فهرس		صحيح  طبيعي		
}؛

النوع		مدخل_تجزئة	شيء {
			اسم			ۢ حرف
			تالي		ۢ		مدخل_تجزئة		
			بيان		 	بيان_تجزئة				
}؛

النوع		 جدول_تجزئة		شيء {
			مداخل			ۢ 	ۢ	مدخل_تجزئة
			حجمه_			صحيح طبيعي 
			اصطدام		صحيح 			
}؛
	
	النوع	م_جدول_تجزئة		ۢ  جدول_تجزئة
	النوع	م_مدخل_تجزئة		ۢ  مدخل_تجزئة		
	النوع	م_م_مدخل_تجزئة		ۢ  ۢ  مدخل_تجزئة	
						
		(۩		تخصيص جدول تجزئة جديد	۩)		
	الدالة		جدول_جديد	(	حجم_ صحيح طبيعي	)	ۢ  جدول_تجزئة	{
			 المتغير		جديد		ۢ  جدول_تجزئة	
			جديد		:=			ذاكرة::تخصيص(	حجم(	ڨ جديد)	)		كما م_جدول_تجزئة	 
			جديد->حجمه_	:=		حجم_				
			جديد->اصطدام	:=		0
			جديد->مداخل	:=			ذاكرة::تخصيص(حجم_		×	حجم	(	ڨ جديد->مداخل 	)	)	كما م_م_مدخل_تجزئة		
					ذاكرة::تعيين	(جديد->مداخل ، 0، حجم_	×	حجم	(	ڨ جديد->مداخل 	)	 )		
			ارجع 	جديد		
		}		

	(۩	    	۩)
	(۩۩		حساب   صفرة التجزئة	۩)
	الدالة		صفرة_التجزئة	(	 اسم 	ۢ حرف	)  صحيح طبيعي 	{
				المتغير		ت		صحيح طبيعي		:=		5381
				المتغير		ص 	حرف
				
				مادام		(ص		:=	(	ڨ اسم	 ))	 ليس= '/0'	{
								ت :=		(	(ت >> 5)	+ ت  )			+ ص كما صحيح طبيعي
						 اسم++								
				}

				ارجع ت				
	}

	(۩		     	۩)	
	(۩۩		حساب طول صفرة التجزئة	۩)
	الدالة		صفرة_التجزئة_طول	(	 اسم 	ۢ حرف	، طول_		صحيح 	طبيعي)  صحيح طبيعي 	{
		المتغير		ت		صحيح طبيعي		:=		5381
	 	
			مادام		طول_-- > 0 {
				ت :=		(	(ت >> 5)	+ ت  )	+ (	ڨ اسم++	 )   كما صحيح طبيعي
			}
			ارجع		ت		
	}
		(۩		    	۩)	
		(۩۩		اضافة مدخل الى جدول التجزئة	۩)
	الدالة			(	جت	ۢ  جدول_تجزئة	)		اضف_مدخل	(	 اسم 	ۢ حرف	، بيان		   بيان_تجزئة	) 	{
				المتغير			ا	صحيح	طبيعي 	:=		صفرة_التجزئة		(	اسم	) 	نمط	جت->حجمه_
				المتغير		مدخل_جديد		ۢ		مدخل_تجزئة		:=			ذاكرة::تخصيص( 	حجم	(	ڨ	مدخل_جديد	)	)		كما م_مدخل_تجزئة
				مدخل_جديد->اسم :=	اسم			
				مدخل_جديد->تالي	:= عدم			؛	 
				مدخل_جديد->بيان :=	بيان		
				مدخل_جديد->تالي	:=	جت->مداخل[ا]		
				جت->مداخل[ا]		:= 	مدخل_جديد			
				
	}
	(۩		    	۩)		
	(۩۩		حذف مدخل الى جدول التجزئة	۩)
	الدالة			(	جت	ۢ  جدول_تجزئة	)		حذف_مدخل	(	 اسم 	ۢ حرف 	) 	{
		المتغير			ا	صحيح	طبيعي 	:=		صفرة_التجزئة		(	اسم	) 	نمط	جت->حجمه_
		المتغير		م	، اخير	ۢ		مدخل_تجزئة
		لاجل		م	:=		جت->مداخل[ا]	، اخير	:= عدم			؛	م ليس= عدم ؛	م:=		م->تالي {
				اذا		نصيات::مطابق 	( اسم،		م->اسم		) {
						اذا اخير	=  عدم	{
							جت->مداخل[ا]	:=	م->تالي
						} والا	{
							اخير->تالي		:=	م->تالي
						}
						ذاكرة::تحرير	(	م	)	
						ارجع						
				}	
				اخير	:=	م				
		}
	}

	(۩		    	۩)	
	(۩۩		البحث وجلب  مدخل من جدول التجزئة	۩)
	الدالة			(	جت	ۢ  جدول_تجزئة	)		اجلب_مدخل	(	 اسم 	ۢ حرف 	،	بيان  	 ۢ  بيان_تجزئة) 	منطقي		{
			المتغير			ا	صحيح	طبيعي 	:=		صفرة_التجزئة		(	اسم	) 	نمط	جت->حجمه_
		 	المتغير		م 	ۢ		مدخل_تجزئة		

		لاجل		م	:=		جت->مداخل[ا]	 		؛	م ليس= عدم ؛	م:=		م->تالي {
				اذا	م ليس= عدم 	و نصيات::مطابق 	( اسم،		م->اسم		) {
					ڨ بيان :=	 م->بيان		
					ارجع		صواب	
				} والا	{
					جت->اصطدام++
				}
			}
			ارجع		خطا			
	}

		الدالة			(	جت	ۢ  جدول_تجزئة	)		وجود_مدخل	(	 اسم 	ۢ حرف ) 	منطقي		{
			المتغير			ا	صحيح	طبيعي 	:=		صفرة_التجزئة		(	اسم	) 	نمط	جت->حجمه_
		 	المتغير		م 	ۢ		مدخل_تجزئة		

		لاجل		م	:=		جت->مداخل[ا]	 		؛	م ليس= عدم ؛	م:=		م->تالي {
				اذا	م ليس= عدم 	و نصيات::مطابق 	( اسم،		م->اسم		) {
					ارجع		صواب	
				} والا	{
					جت->اصطدام++
				}
			}
			ارجع		خطا			
	}


	(۩		    	۩)	
			(۩۩		البحث وجلب  مدخل من جدول التجزئة	۩)
	الدالة			(	جت	ۢ  جدول_تجزئة	)		اجلب_مدخل	(	 اسم 	ۢ حرف	، طول_ صحيح طبيعي	، بيان 	 ۢ  بيان_تجزئة	) 	منطقي	{
			المتغير			ا	صحيح	طبيعي 	:=		صفرة_التجزئة_طول		(	اسم	، طول_) 	نمط	جت->حجمه_
		 	المتغير		م 	ۢ		مدخل_تجزئة		

			لاجل		م	:=		جت->مداخل[ا]	 		؛	م ليس= عدم ؛	م:=		م->تالي {
				اذا		نصيات::مقارنة( اسم،		م->اسم		، طول_	كما صحيح) = 0 و 	م->اسم[طول_] = '/0' {
					ڨ بيان :=	 م->بيان		
					ارجع صواب 							
				} والا	{
					جت->اصطدام++
				}
			}
			ارجع		خطا			
	}
		
	
