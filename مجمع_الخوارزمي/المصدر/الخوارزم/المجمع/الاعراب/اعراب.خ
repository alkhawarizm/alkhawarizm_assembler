	(۩۩
			تحليل_تعليمة: استخراج وتحليل اسم التعليمة من السطر المرئي
			
			هذه الدالة تقوم بقراءة اسم التعليمة x86-64 من السطر المدخل وفصل أي لاحقات حجمية
			(ب للبايت، و للكلمة، ل للطويل، ق للرباعي، س للخاص، ش للممتد). 
			
			المعاملات:
			- س: مؤشر إلى بداية السطر الذي يحتوي على اسم التعليمة
			- طول_تعليمة: مؤشر لتخزين طول اسم التعليمة بدون لاحقة
			- امتداد: مؤشر إلى مصفوفة لتخزين أسماء اللاحقات المكتشفة
			- طول_امتداد: مؤشر إلى مصفوفة لتخزين أطوال اللاحقات
			- عدد_امتداد: مؤشر لتخزين عدد اللاحقات المكتشفة (0 أو 1)
			
			القيمة المرجعة:
			مؤشر إلى بداية السطر الأصلي. في حالة الخطأ، تُكتب رسالة خطأ ويُرجع نفس المؤشر.
			
			رموز الخطأ:
			- 10: اسم التعليمة فارغ (لا توجد أحرف للاسم)
			- 11: التعليمة غير معروفة (لم تُجد في جدول الرموز)
		۩۩)	
	
		الدالة		تحليل_تعليمة (		س ۢ حرف، طول_تعليمة ۢ صحيح طبيعي، امتداد ۢ ۢ حرف، طول_امتداد ۢ صحيح طبيعي، عدد_امتداد ۢ صحيح طبيعي	) ۢ حرف {
						المتغير		بداية 	ۢ حرف 	:= س              ؛                 (۩ احفظ موضع البداية ۩)
						ليكن		ط := 0_ط                   ؛               (۩ عداد الطول ۩)
						ليكن		بيان جداول_التجزئة::بيان_تجزئة  ؛       (۩ مدخل جدول الرموز ۩)
						
						(۩ استخرج اسم التعليمة - تكرار حتى مسافة أو فاصلة أو نهاية السطر ۩)
						مادام	ليس سلسلة::حرف_مساحة(ڨ س)   و  ليس تركيب::نهاية_السطر(س)  و  ڨ س ليس= '،'  {
								س++
						}
						ط :=	( س - بداية) كما صحيح طبيعي
						
												(۩ تحقق من اللاحقات: ب (قطعة)، و (كلمة)، ل (طويلة)، ق (رباعية)، س (سلسلة)، ش (ممتدة) ۩)
						ڨ عدد_امتداد := 0
							(۩  لا نعالج الاحقات هنا. لم يتم اختيرا اللاحقات وشكلها بعد ۩)							
		اذا خطا و ط > 0  و  (ڨ (س-1) = 'ب'  او   ڨ (س-1) = 'و'  او  (۩ ڨ (س-1) = 'ل'  او۩)   ڨ (س-1) = 'ق'  او
								  ڨ (س-1) = 'س'  او   ڨ (س-1) = 'ش')  {
								(۩ تم العثور على لاحقة ۩)؛
								ڨ امتداد := س-1       ؛            (۩ أشر إلى حرف اللاحقة ۩)
								ڨ طول_امتداد := 1            ؛            (۩ اللاحقة حرف واحد ۩)
								ڨ عدد_امتداد := 1              ؛           (۩ لاحقة واحدة ۩)
								ڨ طول_تعليمة := ط - 1          ؛          (۩ طول التعليمة بدون لاحقة ۩)
						}  والا  {
								(۩ بدون لاحقة ۩)
								ڨ طول_تعليمة := ط
						}
						(۩ تحقق من التعليمة: ابحث في جدول الرموز ۩)
						اذا ڨ طول_تعليمة > 0  {
								اذا ليس رموز::جدول_الوسوم()->اجلب_مدخل(بداية، ڨ طول_تعليمة، ؏بيان)  {
(۩								اذا ليس رموز::جدول_الوسوم()->اجلب_مدخل(بداية ، ؏بيان)  {۩)
										اخطاء::اكتب_خطا_نحوي(11)  ؛        (۩ تعليمة غير معروفة ۩)
										ارجع بداية  ؛                       (۩ أرجع بدون تغيير عند الخطأ ۩)
								}
						}  والا  {
								اخطاء::اكتب_خطا_نحوي(10)  ؛             (۩ اسم التعليمة فارغ ۩)
								ارجع بداية
						}
						 
						ارجع س
		}

