	الدالة		تحليل_معامل_سجل (	معامل_نص ۢ حرف ، طوله صحيح ، عامل_معامل ۢ عناصر::معامل	) منطقي {
					المتغير		س ۢ حرف := معامل_نص              ؛ (۩ مؤشر البداية ۩)
					المتغير		النهاية 	ۢ حرف := معامل_نص + طوله ؛ (۩ علامة النهاية ۩)
					المتغير		اسم_سجل 	 ۢ حرف	  	:=	""  ؛ (۩ مخزن اسم السجل المؤقت ۩)
					المتغير		طول_الاسم		صحيح		:=	0		؛
					المتغير		رمز_س		ۢ معالج::رمز_سجل	:=	عدم	؛
					
					(۩ تجاهل % إن وجدت ۩)
					اذا ڨ س = '٪' {
							س++
					}
					
