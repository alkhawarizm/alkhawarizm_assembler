				حالة 'خ' { علامات_ اواو=   مقتطع_ذاكرة 	كما صحيح طبيعي	؛ }
				حالة 'ك' { علامات_ اواو=   مقتطع_كتابة	كما	صحيح طبيعي؛  }
				حالة 'ن' { علامات_ اواو=  مقتطع_تنفيذ 	كما	صحيح طبيعي؛  }
				حالة 'ص' { علامات_ اواو= مقتطع_تنفيذ كما صحيح طبيعي ؛ }
				حالة 'ق' { علامات_ اواو= مقتطع_ذاكرة كما صحيح طبيعي ؛ }				
			}
		}
		ارجع علامات_
	}

