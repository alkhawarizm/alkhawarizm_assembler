الدالة كتابة_جدول_الرموز32 (بمرجع م مخزن_ذاكرة ، بمرجع ق قوائم::قائمة) {
    المتغير ع ۢ قوائم::عقدة := ق.اول
(۩    شاشة::اكتب("كتابة_جدول_الرموز32: حجم قبل=") ؛ شاشة::اكتب(م.حجم_) ؛ '/س'.اكتب()۩)
    مادام ع ليس= عدم {
        المتغير عق ۢ عقدة_رمز32 := ع كما ۢ عقدة_رمز32
(۩        شاشة::اكتب("  كتابة رمز حجم=") ؛ شاشة::اكتب(حجم(رمز32))۩)
(۩        شاشة::اكتب(" عنوان_راس=") ؛ شاشة::اكتب((؏عق->راس) كما صحيح طبيعي)۩)
(۩        '/س'.اكتب()۩)
        م.اكتب(؏عق->راس ، حجم(رمز32))
(۩        شاشة::اكتب("  حجم بعد=") ؛ شاشة::اكتب(م.حجم_) ؛ '/س'.اكتب()۩)
        ع := ع->تالي
    } 
(۩    شاشة::اكتب("كتابة_جدول_الرموز32: حجم بعد=") ؛ شاشة::اكتب(م.حجم_) ؛ '/س'.اكتب()۩)
}

