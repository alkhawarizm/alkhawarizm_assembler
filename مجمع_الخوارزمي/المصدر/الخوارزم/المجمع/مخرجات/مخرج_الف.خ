		}
		لاجل ا   := 0 ؛ صفة[ا] ليس= '/0' ؛ ا++ {
			طابق صفة[ا] {
				حالة 'ص'،  'ه' {  ارجع مقتطع_برمجيات   ؛ }
				حالة 'غ'   {  ارجع لا_بثات		 ؛ }
			}
		}
		ارجع مقتطع_برمجيات 
