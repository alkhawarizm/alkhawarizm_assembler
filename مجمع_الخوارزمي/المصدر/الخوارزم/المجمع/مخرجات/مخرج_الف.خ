	الدالة كتابة_بيانات_المقتطع ( بمرجع م  مخزن_ذاكرة، مق ۢ مقتطعات::مقتطع   ) {
		المتغير ع ۢ عناصر::عنصر := مق->اول
		المتغير عداد معالج::ع_الهدف_ط := 0
		ليكن ا  := 0					
		مادام ع ليس= عدم {
			المتغير ن_عداد معالج::ع_الهدف_ط
		ن_عداد	 :=  عناصر::تراصف_عداد_البرنامج (ع ، عداد كما صحيح) كما صحيح طبيعي
		اذا ن_عداد > عداد {
				المتغير حشو_حجم صحيح := (ن_عداد - عداد) كما صحيح
				
				لاجل ا := 0 ؛ ا < حشو_حجم ؛ ا++ {
					المتغير صفر صحيح8 طبيعي := 0
					م.اكتب(؏صفر ، 1  )
				}
			}
			طابق ع->نوعه {
				حالة   عناصر::بيانات  { 
					م.اكتب(ع->محتوى.بنية_بيان->بيان ، ع->محتوى.بنية_بيان->حجمها  )
				}					
				حالة عناصر::مساحة { 
					لاجل ا := 0 ؛ ا < (ع->محتوى.بنية_مساحة->مساحة × ع->محتوى.بنية_مساحة->حجمها) كما صحيح ؛ ا++ {
						م.اكتب(؏ع->محتوى.بنية_مساحة->ملء[0] ، 1 )
					}
				}
			}			
			عداد := ن_عداد  		+ 	عناصر::حجم_عنصر(ع ، مق ، ن_عداد كما معالج::ع_الهدف)
			ع := ع->تالي
	
		}
	}
	
	
	(۩۩	
