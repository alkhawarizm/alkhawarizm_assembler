		اذا رم_->مقتطع_ ليس= عدم {
			المتغير مق ۢ مقتطعات::مقتطع := رم_->مقتطع_ كما ۢ مقتطعات::مقتطع
(۩ 			   شاشة::اكتب("فهرس [") ؛ شاشة::اكتب_عجمي(مق->اسمه)۩)
(۩  			  شاشة::اكتب("] = ") ؛ شاشة::اكتب(مق->فهرس) ؛ '/س'.اكتب()۩)
(۩			 شاشة::اكتب("عنوان مقتطع الرمز: ") ؛ شاشة::اكتب(مق كما صحيح  طبيعي) ؛ '/س'.اكتب()۩)

