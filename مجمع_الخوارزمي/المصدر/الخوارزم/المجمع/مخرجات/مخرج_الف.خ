(۩    المتغير رم_ ۢ رموز::رمز := رموز::الرمز_الاول()۩)
    (۩ ── تمرير 1: المحليون (وسوم في مقتطع، غير مصدَّرة) ── ۩)
(۩	شاشة::اكتب("تمرير 1 (محليون): ")۩)
    مادام رم_ ليس= عدم {
     اذا رم_->نوعه = رموز::رمز_وسم    و (رم_->علامة وو (رموز::تصدير اواو رموز::ضعيف)) = 0  {
           المتغير عق_ر ۢ عقدة_رمز32 := ذاكرة::تخصيص(حجم(عقدة_رمز32)) كما ۢ عقدة_رمز32
(۩				 شاشة::اكتب("[") ؛ شاشة::اكتب_عجمي(رم_->اسمه) ؛ شاشة::اكتب(" فلأغس: ")؛ شاشة::اكتب(رم_->علامة) ؛  ؛ شاشة::اكتب("] ")			۩)
					حسابيات::عين_قيمة(ا_كبير ، ؏عق_ر->راس.اسم_ ، 4 ، اضافة_نص(ج_نصوص ، رم_->اسمه) كما صحيح64 طبيعي)
					حسابيات::عين_قيمة(ا_كبير ، ؏عق_ر->راس.قيمة ، 4 ، جلب_قيمة_الرمز(رم_) كما صحيح64 طبيعي)
					حسابيات::عين_قيمة(ا_كبير ، ؏عق_ر->راس.حجم_ ، 4 ، جلب_حجم_الرمز(رم_) كما صحيح64 طبيعي)
					عق_ر->راس.معلومات[0] := معلومات_الرمز(ربط_محلي كما صحيح8 طبيعي ، جلب_معلومات_الرمز(رم_))
					حسابيات::عين_قيمة(ا_كبير ، ؏عق_ر->راس.فهرس_المقتطع ، 2 ،جلب_فهرس_مقتطع_الرمز(رم_) كما صحيح64 طبيعي)
					عق_ر->فهرس := فهرس_م
					رم_->فهرس := فهرس_م
					فهرس_م++
					(ڨ ق_رموز).اضف_ذيل(؏عق_ر->عقدة_)
            اول_عام++
        }
        رم_ := رم_->تالي
    }
(۩	'/س'.اكتب()    ۩)
