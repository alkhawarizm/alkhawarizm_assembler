		المتغير ا صحيح		
		هوية[مميز0] := 0س7و
		هوية[مميز1] := 'ُ' كما صحيح8 طبيعي
		هوية[مميز2] := 'ۙ' كما صحيح8 طبيعي
		هوية[مميز3] := 'َ' كما صحيح8 طبيعي
		هوية[صنف] := صنف_
		هوية[بيان] := نهاية_كبيرة ؟ 2_ط8 : 1_ط8
		هوية[اصدار] := اصدار_حالي  كما صحيح8 طبيعي
		لاجل ا := حشوة ؛ ا < محدد ؛ ا++ {
