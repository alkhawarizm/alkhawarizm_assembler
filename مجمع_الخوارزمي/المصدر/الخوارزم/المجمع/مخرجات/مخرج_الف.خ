	(۩	
		addString: تضافة نص جديد إلى جدول النصوص.
		المدخلات: 'ج' هو جدول النصوص، 'ن' هو النص المطلوب إضافته.
		المخرجات: فهرس النص (الإزاحة) داخل جدول النصوص.
	۩)
	الدالة اضافة_نص ( ج ۢ جدول_نصوص ، ن ۢ حرف ) صحيح طبيعي {
		المتغير عق ۢ عقدة_نص := ذاكرة::تخصيص(حجم(عقدة_نص)) كما ۢ عقدة_نص
		المتغير ف صحيح طبيعي := ج->فهرس
		عق->نص := ن
			 ج->قائمة_. اضف_ذيل( ؏عق->عقدة_)		
		ج->فهرس +=  (نصيات::طولها(ن) +  1)  كما صحيح طبيعي
		ارجع ف
	}

	(۩	
		write_strtab: كتابة جميع القيمة المخزنة في جدول النصوص إلى الملف.
		العملية: تقوم بمسح القائمة وكتابة كل نص متبوعاً بصفر (Null-terminator).
	۩)
	الدالة كتابة_جدول_النصوص (بمرجع م مخزن_ذاكرة ، ج ۢ جدول_نصوص) {
    المتغير ع ۢ قوائم::عقدة := ج->قائمة_.اول
    مادام ع ليس= عدم {
        المتغير عق ۢ عقدة_نص := ع كما ۢ عقدة_نص
        م.اكتب(عق->نص ، نصيات::طولها(عق->نص) كما صحيح طبيعي + 1_ط)
        ع := ع->تالي
    }
}

