	(۩ تهيئة المخزن بسعة مبدئية 64 كيلوبايت ۩)
	الدالة   (بمرجع م مخزن_ذاكرة) تهيئة() {
	    م.سعة := 64 × 1024 ؛
	    م.بيانات := ذاكرة::تخصيص (1، م.سعة) كما ۢ صحيح8 طبيعي ؛
	    م.حجم_ := 0 ؛
	}
	
	(۩ التأكد من وجود مساحة كافية ۩)
	الدالة 	(بمرجع م مخزن_ذاكرة) ضمان_مساحة  (  مطلوب صحيح طبيعي)  {
	    مادام م.حجم_ + مطلوب > م.سعة {
	        م.سعة := م.سعة × 2 ؛
	        م.بيانات := ذاكرة::اعادة_تخصيص(م.بيانات، م.سعة) كما ۢ صحيح8 طبيعي ؛
	        (۩ تصفير المساحة الجديدة المضافة ۩)
	        ذاكرة::تعيين(م.بيانات + م.حجم_، 0، م.سعة - م.حجم_) ؛
	    }
	}
	
	(۩ الكتابة في الموضع الحالي مع تقديم المؤشر ۩)
	الدالة   (بمرجع م مخزن_ذاكرة)  اكتب(  مصدر  ايما،  طول_ صحيح طبيعي) {
	    م.ضمان_مساحة(طول_) ؛
	    ذاكرة::نسخ(م.بيانات + م.حجم_، مصدر، طول_) ؛
	    م.حجم_ := م.حجم_ + طول_ ؛
	}
	
	(۩ الكتابة في إزاحة محددة - تستخدم لعمل Patch لعناوين الـ ELF ۩)
	الدالة    اكتب_في(بمرجع م مخزن_ذاكرة، إزاحة صحيح طبيعي، مصدر  ايما، طول_ صحيح طبيعي) {
	    (۩ التأكد من أن المخزن كبير بما يكفي لهذه الإزاحة ۩)
	    اذا إزاحة + طول_ > م.سعة {
	        مادام إزاحة + طول_ > م.سعة { م.سعة := م.سعة × 2 ؛ }
	        م.بيانات := ذاكرة::اعادة_تخصيص(م.بيانات، م.سعة) كما ۢ صحيح8 طبيعي ؛
	        ذاكرة::تعيين(م.بيانات + م.حجم_، 0، م.سعة - م.حجم_) ؛
	    }
	    ذاكرة::نسخ(م.بيانات + إزاحة، مصدر، طول_) ؛
	    
	    (۩ إذا كتبنا وراء الحجم الحالي، نقوم بتحديث الحجم ۩)
	    اذا إزاحة + طول_ > م.حجم_ {
	        م.حجم_ := إزاحة + طول_ ؛
	    }
	}
	
