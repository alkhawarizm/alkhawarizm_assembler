الصنف تجميع {
		 
(۩ عملية التجميع الأساسية بدون التعامل مع DWARF ۩)
	الدالة  عملية_تجميع()  {
    (۩ متغيرات لضبط العناوين وعداد البرنامج ۩)
    المتغير  عداد_اساسي ، عداد_اصل_مرحل ، عداد_اصل  معالج::ع_الهدف
    المتغير  مساحة_بين ، ترحيل_اصل  منطقي
    المتغير  مق  ۢ مقتطعات::مقتطع
    المتغير  ع ، عا  ۢ عناصر::عنصر
    المتغير  مرحلة_اخيرة  منطقي  := صواب

    (۩ 1. تحويل الوسوم النسبية إلى عناوين ثابتة قبل البدء ۩)
    مقتطعات::تحويل_وسوم_الازاحة()

    ترحيل_اصل := خطا

    (۩ 2. الدوران على جميع مقاطع البرنامج (.text, .data, .bss) ۩)
    لاجل مق := مقتطعات::حصل_المقطع_الاول() ؛ مق ليس= عدم؛ مق := مق->تالي {
        المتغير  مصدر_خطا_سابق  ۢ مصادر::مصدر  := عدم
        المتغير  عداد_قديم  معالج::ع_الهدف
        المتغير  سطر_خطا_سابق  صحيح  := 0
        المتغير  تجاوز  منطقي  := خطا
        
        (۩ ضبط نقطة البداية للمقطع الحالي ۩)
        مق->عداد_البرنامج := مق->اصل
        
        (۩ التحقق إذا كان المقطع مخصصاً للبيانات غير المهيأة (bss) ۩)
        مساحة_بين := مق->اسمه.بحث(0 ، مق->اسمه->طولها() +1  ،'ى'  ) > 0

        (۩ 3. معالجة العناصر  داخل المقطع واحداً تلو الآخر ۩)
        لاجل ع := مق->اول؛ ع ليس= عدم؛ ع := ع->تالي {
            المتغير مصدر_حالي ۢ مصادر::مصدر := ع->مصدر
            عداد_اساسي := مق->عداد_البرنامج
            
            (۩ تطبيق قواعد التراصف (Alignment) لضمان صحة عنوان العنصر ۩)
            مق->عداد_البرنامج := عناصر::تراصف_عداد_البرنامج(ع، مق->عداد_البرنامج)

            اذا مصدر_حالي ليس= عدم {
                مصدر_حالي->سطر := ع->سطر
            }
            
            (۩ ربط الرمز (الوسم) بالعنوان الحالي في عداد البرنامج ۩)
            اذا ع->تسجيل_ ليس= عدم و (ع->تسجيل_->عنصر كما ۢ عناصر::عنصر) =  ع {
                ع->تسجيل_->مقتطع := مق
                ع->تسجيل_->عب := مق->عداد_البرنامج
            }
            
            (۩ مراقبة حجم التعليمات؛ إذا تغيرت كثيراً نطلق تحذيراً ۩)
            اذا ع->تغيرات > 5 { (۩ MAXSIZECHANGES ۩)
                مق->علامة اواو= مقتطعات::حل_التنبيه
            }

            (۩ 4. كشف الأخطاء: التحذير عند حدوث تراصف تلقائي يغير العنوان ۩)
            اذا مق->عداد_البرنامج ليس= عداد_اساسي {
                اذا ع->نوعه = عناصر::وسم و ع->تالي ليس= عدم و ع->تالي->سطر = ع->سطر {
                    عا := ع->تالي
                } والا {
                    عا := ع
                }
                
                اذا عا->نوعه = عناصر::تعليمات {
                    اخطاء::اكتب_خطا_عام(50)؛ (۩ تعليمة تراصفت تلقائياً ۩)
                } والا اذا عا->نوعه = عناصر::بيانات او عا->نوعه = عناصر::تعريف_بيان {
                    اخطاء::اكتب_خطا_عام(57)؛ (۩ بيانات تراصفت تلقائياً ۩)
                }
            }
                
            (۩ 5. المحرك الأساسي: معالجة أنواع العناصر المختلفة ۩)
            طابق ع->نوعه {
                
                (۩ حالة تغيير أصل المقطع (ORG) ۩)
                حالة عناصر::اصل {
                    عداد_اصل_مرحل := ڨ ع->محتوى.اصل
                    عداد_اصل := مق->عداد_البرنامج
                    مق->عداد_البرنامج := عداد_اصل_مرحل
                    مق->علامة اواو= مقتطعات::مطلق
                    ترحيل_اصل := صواب
                }
                
                (۩ حالة العودة من الأصل المرحل ۩)
                حالة عناصر::نهاية_اصل {
                    اذا ترحيل_اصل {
                        مق->عداد_البرنامج := عداد_اصل + (مق->عداد_البرنامج - عداد_اصل_مرحل)
                        عداد_اصل_مرحل := 0
                        مق->علامة وو= متمم مقتطعات::مطلق
                        ترحيل_اصل := خطا
                    } والا {
                        اخطاء::اكتب_خطا_عام(44)
                    }
                }           
                
                (۩ حالة التعليمات: تحويل "النص" إلى "بنية بيانات ثنائية" ۩)
                حالة عناصر::تعليمات {
                    المتغير بب ۢ عناصر::بنية_بيان := عدم
                    تسجيلات::تعيين_تسجيل_اول (ع->تسجيل_)   
                    بب :=  مقتطعات::تقييم_تعليمة(ع->محتوى.تعليمة_، مق، مق->عداد_البرنامج )
                    
                    (۩ التحقق من صحة العناوين في الأكواد المستقلة عن الموقع ۩)
                    اذا  تموقعات::هل_تموقع_غير_نسبي()   {
                        تموقعات::تحقق_تموقع_غير_نسبي(بب->تموقعات)
                    }
                    تسجيلات::تعيين_تسجيل_اول (عدم)  
                    
                    (۩ "تجميد" التعليمة وتحويل نوعها إلى بيانات نهائية ۩)
                    ع->محتوى.بنية_بيان := بب
                    ع->نوعه := عناصر::بيانات
                }
                
                (۩ حالة تعريف البيانات (مثل .byte أو .long) ۩)
                حالة عناصر::تعريف_بيان {
                    المتغير بب ۢ عناصر::بنية_بيان
                    بب := تموقعات::تقييم_بيانات(ع->محتوى.بنية_تعريف->معامل_، ع->محتوى.بنية_تعريف->حجم_بث كما صحيح طبيعي،
                                                                                                    مق، مق->عداد_البرنامج)
                    اذا تموقعات::هل_تموقع_غير_نسبي()  {
                        تموقعات::تحقق_تموقع_غير_نسبي(بب->تموقعات)
                    }
                    ع->محتوى.بنية_بيان := بب
                    ع->نوعه := عناصر::بيانات
                }
                
                (۩ حالة حجز المساحة (مثل .space أو .skip) ۩)
                حالة عناصر::موقع_نسبي {
                    المتغير بم ۢ عناصر::بنية_مساحة
                    المتغير مساحة معالج::ع_الهدف
                    اذا مقتطعات::تقييم_تعبير_داخلي(ع->محتوى.موقع_نسبي، ؏مساحة، مق، مق->عداد_البرنامج، 0)  {
                        مساحة := مق->اصل + مساحة - مق->عداد_البرنامج
                        اذا مساحة >= 0 {
                            بم := عناصر::بنية_مساحة_جديدة(تعبيرات::تعبير_عدد(مساحة)، 1، 0)
                            ع->محتوى.بنية_مساحة := بم
                            ع->نوعه := عناصر::مساحة
                        } والا {
                            اخطاء::اكتب_خطا_عام(20)
                        }
                    } والا {
                        اخطاء::اكتب_خطا_عام(30)
                    }
                }
            }

            (۩ 6. منع وضع بيانات مهيأة في مقاطع الـ BSS غير المخصصة ۩)
            اذا ع->نوعه = عناصر::بيانات و مساحة_بين {
                اذا مصدر_خطا_سابق ليس= ع->مصدر او سطر_خطا_سابق ليس= ع->سطر {
                    اذا (مق->علامة وو مقتطعات::غير_محدد) ليس= 0 {
                        اخطاء::اكتب_خطا_عام(54)؛ (۩ بيانات في مقطع إزاحة ۩)
                    } والا {
                        اخطاء::اكتب_خطا_عام(31) ؛(۩ بيانات مهيأة في مساحة bss ۩)
                    }
                    مصدر_خطا_سابق := ع->مصدر
                    سطر_خطا_سابق := ع->سطر
                }
            }

            (۩ 7. تحديث عداد البرنامج بناءً على الحجم الفعلي للعنصر ۩)
            عداد_قديم := مق->عداد_البرنامج
            مق->عداد_البرنامج += مقتطعات::حجم_عنصر(ع، مق، مق->عداد_البرنامج) كما معالج::ع_الهدف
            
            (۩ كشف تجاوز حدود الذاكرة المتاحة ۩)
            اذا مق->عداد_البرنامج ليس= عداد_قديم {
                اذا (مق->عداد_البرنامج - 1) < عداد_قديم او تجاوز {
                    اخطاء::اكتب_خطا_عام(45) ؛ (۩ تجاوز مساحة العنوان ۩)
                }
                تجاوز := (مق->عداد_البرنامج = 0)
            }
            مق->علامة وو= متمم مقتطعات::حل_التنبيه
        }

        (۩ التأكد من الخروج من وضع الأصل المرحل عند نهاية المقطع ۩)
        اذا ترحيل_اصل {
            مق->عداد_البرنامج := عداد_اصل + (مق->عداد_البرنامج - عداد_اصل_مرحل)
            عداد_اصل_مرحل := 0
            مق->علامة وو= متمم مقتطعات::مطلق
            ترحيل_اصل := خطا
        }
    }
    
    (۩ 8. تنظيف الذاكرة وإزالة المقاطع غير المستخدمة ۩)
    مقتطعات::ازالة_مقتطعات() 
}

		 
						 

