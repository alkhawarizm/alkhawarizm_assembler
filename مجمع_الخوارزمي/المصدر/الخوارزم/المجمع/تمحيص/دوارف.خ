	الدالة		صناعة_قوائم_ملف		(	اول_مصدر	 ۢ 	مصادر::ملف_المصدر	)	خاص	{
		
			المتغير		عقدة_مصدر			 ۢ 	مصادر::ملف_المصدر	
			المتغير		عقدة_شمل			 ۢ 	مصادر::مسار_الشمل
			المتغير		ملف_جديد	،	ملف_دو		ۢ	ملف	
			المتغير		شمل_جديد_ ،		شمل_دو		ۢ	شمل

			المتغير		خزان_مسار	[1024]	حرف	؛	(۩		مرفقات::اكرب_طول_مسار	۩)		
			المتغير		جزء_ملف		ۢ	حرف
			المتغير		فهرس_شمل،		فهرس_ملف	، ا 	صحيح	:=		0	،	0	،	0

			اول_شمل		:= عدم		
			اول_ملف		:=	عدم

			لاجل		عقدة_مصدر	:=	اول_مصدر		؛	عقدة_مصدر	ليس= عدم ؛		عقدة_مصدر	:=	عقدة_مصدر->تالي	{
					ملف_جديد		:=	ذاكرة::تخصيص	( حجم(	ملف)	)	كما		ۢ	ملف	
				 	ملف_جديد->تالي	:=	عدم				
				 	خزان_مسار	[0]	:=	'/0'	
					
					اذا 		(عقدة_شمل	:=	عقدة_مصدر->مسار_شمل	) ليس= عدم {
						اذا	عقدة_شمل->قائم_على_دليل	{
							المتغير		دليل	ۢ	حرف	:=	مصادر::دليل_التجميع 	( )								
							اذا دليل	ليس=  عدم {
								نصيات::نسخ	(خزان_مسار		،	 	دليل	،	دليل.طولها())
							} والا	{
								اخطاء::اكتب_خطا_عام	( 4	)	؛	(۩		 ierror(0);	۩)
							}
							  	نصيات::وصل	( خزان_مسار	 ،		عقدة_شمل->مسار	)							
						}
					}
					اذا (جزء_ملف	:=	 مرفقات::حصل_جزء_ملف	 (	عقدة_مصدر->اسم	))	 ليس= 	عقدة_مصدر->اسم	{
								(۩		إضافة جزء المسار من اسم الملف المصدر	۩)			
							المتغير		طول_		صحيح طبيعي		:=	(جزء_ملف	- عقدة_مصدر->اسم	)	كما صحيح طبيعي
							المتغير		م	ۢ حرف		:=		نصيات::موضع_عكسي(خزان_مسار	،	'/0'	)	
							ذاكرة::نسخ	(	م	،عقدة_مصدر->اسم	، 	طول_)		
							ڨ (	م	+	طول_	)	:= '/0'						
					}
					اذا 	خزان_مسار[0] ليس= '/0'	{
							المتغير		مسارجديد		ۢ حرف	:=	مرفقات::حذف_محدد_المسار	(	خزان_مسار	)	
							(۩		تحقق مما إذا كان هذا المسار موجودًا بالفعل في القائمة ، وإلا قم بإضافته	۩)		
							اذا		اول_شمل	ليس= عدم 	{
								لاجل		ا	:=	1،	شمل_دو	:=	اول_شمل	؛	؛	ا++	،	شمل_دو := شمل_دو->تالي {
										اذا 	ليس	نصيات::مطابق	(	مسارجديد،	شمل_دو->اسم	)	{
											ذاكرة::تحرير	(	مسارجديد	)	؛	ملف_جديد->فهرس	:=	ا	(۩	استخدام الفهرس الموجود	۩)	؛ قطع
										}
										اذا 	 شمل_دو->تالي		= عدم 	{
											اذا فهرس_شمل	ليس= ا	{		اخطاء::اكتب_خطا_عام	( 4	)	؛	(۩		 ierror(0);	۩)	؛}
											 شمل_دو->تالي	:=	شمل_جديد	(مسارجديد)	؛ ملف_جديد->فهرس	:= ++فهرس_شمل (۩	تضمين الفهرس الجديد	۩)	؛ قطع
										}
								}
							} والا	{
								اول_شمل	:=		شمل_جديد	(مسارجديد)	؛ ملف_جديد->فهرس	:= ++فهرس_شمل (۩	 يجب أن يكون الفهرس 1	۩)	؛  
							}
					} والا	{
						ملف_جديد->فهرس	:=	0		؛	(۩		لا يوجد مسار ، الملف موجود في دليل العمل الحالي	۩)
					}
					(۩		إلحاق عقدة ملف جديد	۩)			
					اذا ++فهرس_ملف	ليس=		عقدة_مصدر->فهرس	{	اخطاء::اكتب_خطا_عام	( 4	)	؛	(۩		 ierror(0);	۩)؛}	
					ملف_جديد->اسم :=		جزء_ملف	
					اذا 	ملف_دو	=		اول_ملف		{
						مادام	ملف_دو->تالي ليس= عدم 	{		ملف_دو :=	ملف_دو->تالي	؛}
						ملف_دو->تالي	:=	ملف_جديد				
					} والا	{
						اول_ملف	:=	ملف_جديد
					}
			}
						
	}

			
